# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flypool"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="<256-bit-random-secret>"
JWT_REFRESH_SECRET="<256-bit-random-secret-for-refresh>"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# App
PORT=3000
NODE_ENV="development"
